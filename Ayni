          </button>
          <button onClick={()=>doSave(post.id)} style={{background:'none',border:'none',cursor:'pointer',padding:'3px 7px',borderRadius:7,display:'flex'}}>
            <Bk on={saved.has(post.id)} p={th.p} c={th.txs}/>
