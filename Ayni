              <Av name={activeContact?.name||'?'} size={32} verified={activeContact?.verified} th={th}/>
              <div>
                <p style={{fontSize:13,fontWeight:700,color:th.tx,margin:0}}>{activeContact?.name}</p>
                {activeContact?.verified&&<p style={{fontSize:10,color:th.p,margin:0,fontWeight:600}}>Cuenta verificada</p>}
              </div>
            </div>
            <div ref={msgRef} style={{flex:1,overflowY:'auto',padding:'1rem',display:'flex',flexDirection:'column',gap:10}}>
              {activeMessages.map(m=>{
                const mine=m.from===user.id;
                return(
                  <div key={m.id} style={{display:'flex',justifyContent:mine?'flex-end':'flex-start'}}>
                    <div style={{maxWidth:'75%',background:mine?th.p:th.sf2||th.l,borderRadius:`12px 12px ${mine?'3px':'12px'} ${mine?'12px':'3px'}`,padding:'9px 13px',animation:'fadeIn .2s ease'}}>
                      <p style={{fontSize:13,color:mine?'white':th.tx,margin:0,lineHeight:1.55}}>{m.text}</p>
                      <p style={{fontSize:10,color:mine?'rgba(255,255,255,.65)':th.txt,margin:'4px 0 0',textAlign:'right'}}>{ago(m.ts)}</p>
                    </div>
                  </div>
                );
              })}
              {activeMessages.length===0&&<div style={{textAlign:'center',color:th.txt,fontSize:13,marginTop:'2rem'}}>Inicia la conversación</div>}
            </div>
            <div style={{padding:'12px 16px',borderTop:`1px solid ${th.bd}`,display:'flex',gap:8}}>
              <input style={{...inp,flex:1}} placeholder="Escribe un mensaje..." value={newMsg} onChange={e=>setNewMsg(e.target.value)}
                onKeyDown={e=>{if(e.key==='Enter')handleSend();}}/>
              <button onClick={handleSend} style={{background:th.p,border:'none',borderRadius:9,padding:'9px 13px',cursor:'pointer',color:'white',display:'flex',flexShrink:0}}><Send c="white"/></button>
            </div>
          </>
        ):<div style={{flex:1,display:'flex',alignItems:'center',justifyContent:'center',flexDirection:'column',gap:8}}>
          <MsgIc s={36} c={th.txt}/>
          <p style={{color:th.txs,fontSize:13}}>Selecciona una conversación</p>
        </div>}
      </div>
    </div>
  );
});

