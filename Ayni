/* ═══ POST DETAIL MODAL (module level) ══════════════════════════ */
const PostDetail=memo(({C})=>{
  const{th,selectedPost,setSelectedPost,posts,liked,saved,doLike,doSave,doComment,commentTxt,setCommentTxt,toast_,go,user}=C;
  const post=posts.find(p=>p.id===selectedPost);
  if(!post)return null;
  const related=posts.filter(p=>p.id!==post.id&&(p.type===post.type||p.mats?.some(m=>post.mats?.includes(m)))).slice(0,4);
  const inp={width:'100%',padding:'9px 12px',border:`1.5px solid ${th.bd}`,borderRadius:9,fontSize:13,background:th.sf,color:th.tx,boxSizing:'border-box',outline:'none'};
  return(
    <div onClick={e=>{if(e.target===e.currentTarget)setSelectedPost(null);}} style={{position:'fixed',inset:0,zIndex:200,background:'rgba(0,0,0,.6)',backdropFilter:'blur(4px)',overflowY:'auto',display:'flex',justifyContent:'center',padding:'20px 12px',animation:'fadeIn .2s ease'}}>
      <div style={{background:th.sf,borderRadius:20,width:'100%',maxWidth:680,height:'fit-content',overflow:'hidden',animation:'slideUp .28s ease'}}>
        <div style={{position:'relative'}}>
          <img src={post.img} alt={post.title} style={{width:'100%',maxHeight:340,objectFit:'cover',display:'block'}}/>
          <button onClick={()=>setSelectedPost(null)} style={{position:'absolute',top:12,left:12,background:'rgba(0,0,0,.55)',border:'none',borderRadius:'50%',width:34,height:34,cursor:'pointer',color:'white',fontSize:18,display:'flex',alignItems:'center',justifyContent:'center',backdropFilter:'blur(4px)'}}>
            <Back c="white"/>
          </button>
          <span style={{position:'absolute',top:12,right:12,background:post.type==='material'?'#0284c7':th.p,color:'white',fontSize:11,fontWeight:700,padding:'4px 10px',borderRadius:100}}>
            {post.type==='material'?'Material':'Proyecto'}
          </span>
        </div>
        <div style={{padding:'1.25rem 1.5rem'}}>
          <div style={{display:'flex',alignItems:'center',gap:9,marginBottom:'1rem'}}>
            <Av name={post.author} size={32} verified={post.verified} th={th}/>
            <div style={{flex:1}}>
              <p style={{fontSize:13,fontWeight:600,color:th.tx,margin:0}}>{post.author}</p>
              <p style={{fontSize:11,color:th.txs,margin:0}}>{ago(post.created)}</p>
            </div>
            {post.type==='material'&&post.location&&<button onClick={()=>window.open(`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(post.location)}`,'_blank')} style={{display:'flex',alignItems:'center',gap:5,padding:'7px 12px',background:th.l,color:th.d,border:'none',borderRadius:9,cursor:'pointer',fontSize:12,fontWeight:600}}>
              <MapIc c={th.d}/>Ver en mapa
            </button>}
          </div>
          <h2 style={{fontSize:20,fontWeight:700,color:th.tx,marginBottom:9,letterSpacing:'-.3px'}}>{post.title}</h2>
          <p style={{fontSize:14,color:th.txs,lineHeight:1.7,marginBottom:'1.1rem'}}>{post.desc}</p>
          {post.mats?.length>0&&<div style={{marginBottom:'1.1rem'}}>
            <p style={{fontSize:11,fontWeight:700,color:th.txs,textTransform:'uppercase',letterSpacing:.5,marginBottom:7}}>Materiales</p>
            <div style={{display:'flex',flexWrap:'wrap',gap:5}}>
              {post.mats.map(m=><span key={m} style={{fontSize:12,background:th.l,color:th.d,padding:'4px 10px',borderRadius:100}}>{m}</span>)}
            </div>
          </div>}
          {post.steps?.length>0&&<div style={{marginBottom:'1.1rem'}}>
            <p style={{fontSize:11,fontWeight:700,color:th.txs,textTransform:'uppercase',letterSpacing:.5,marginBottom:9}}>Proceso paso a paso</p>
            {post.steps.map((s,i)=><div key={i} style={{display:'flex',gap:10,marginBottom:9}}>
              <div style={{width:22,height:22,borderRadius:'50%',background:th.p,color:'white',display:'flex',alignItems:'center',justifyContent:'center',fontSize:10,fontWeight:700,flexShrink:0}}>{i+1}</div>
              <p style={{fontSize:13,color:th.tx,lineHeight:1.55,margin:0,paddingTop:2}}>{s}</p>
            </div>)}
          </div>}
          {post.type==='material'&&post.qty&&<div style={{background:th.l,borderRadius:11,padding:'10px 14px',marginBottom:'1rem',display:'flex',gap:14}}>
            {post.qty&&<div><p style={{fontSize:10,color:th.d,fontWeight:700,textTransform:'uppercase',letterSpacing:.4,margin:'0 0 2px'}}>Disponible</p><p style={{fontSize:13,color:th.d,fontWeight:600,margin:0}}>{post.qty}</p></div>}
            {post.location&&<div><p style={{fontSize:10,color:th.d,fontWeight:700,textTransform:'uppercase',letterSpacing:.4,margin:'0 0 2px'}}>Ubicación</p><p style={{fontSize:13,color:th.d,fontWeight:600,margin:0}}>{post.location}</p></div>}
          </div>}
          <div style={{display:'flex',gap:8,borderTop:`1px solid ${th.bd}`,paddingTop:'1rem',marginBottom:'1rem'}}>
            <button onClick={()=>doLike(post.id)} style={{display:'flex',alignItems:'center',gap:6,padding:'8px 14px',borderRadius:9,border:`1.5px solid ${liked.has(post.id)?'#ef4444':th.bd}`,background:liked.has(post.id)?'#fee2e2':'transparent',color:liked.has(post.id)?'#dc2626':th.txs,cursor:'pointer',fontSize:13}}>
              <Heart on={liked.has(post.id)} s={14} c={th.txs}/>{post.likes}
            </button>
            <button onClick={()=>doSave(post.id)} style={{display:'flex',alignItems:'center',gap:6,padding:'8px 14px',borderRadius:9,border:`1.5px solid ${saved.has(post.id)?th.p:th.bd}`,background:saved.has(post.id)?th.l:'transparent',color:saved.has(post.id)?th.d:th.txs,cursor:'pointer',fontSize:13}}>
              <Bk on={saved.has(post.id)} p={th.p} c={th.txs}/>{saved.has(post.id)?'Guardado':'Guardar'}
            </button>
            <button onClick={()=>toast_('Enlace copiado')} style={{display:'flex',alignItems:'center',gap:6,padding:'8px 14px',borderRadius:9,border:`1.5px solid ${th.bd}`,background:'transparent',color:th.txs,cursor:'pointer',fontSize:13,marginLeft:'auto'}}>
              <Shr c={th.txs}/>Compartir
            </button>
          </div>
          <div style={{marginBottom:'1.25rem'}}>
            <p style={{fontSize:12,fontWeight:700,color:th.txs,textTransform:'uppercase',letterSpacing:.4,marginBottom:11}}>Comentarios ({post.comments?.length||0})</p>
            {post.comments?.map(c=><div key={c.id} style={{display:'flex',gap:8,marginBottom:10}}>
              <Av name={c.author} size={26} th={th}/>
              <div style={{background:th.sf2,borderRadius:10,padding:'7px 11px',flex:1}}>
                <div style={{display:'flex',gap:7,alignItems:'baseline',marginBottom:3}}>
                  <span style={{fontSize:12,fontWeight:700,color:th.tx}}>{c.author}</span>
                  <span style={{fontSize:10,color:th.txt}}>{ago(c.ts)}</span>
                </div>
                <p style={{fontSize:13,color:th.txs,margin:0,lineHeight:1.5}}>{c.text}</p>
              </div>
            </div>)}
            {user?<div style={{display:'flex',gap:8,marginTop:8}}>
              <Av name={user.name} avatar={user.avatar} size={26} th={th}/>
              <input style={{...inp,flex:1}} placeholder="Añadir comentario..." value={commentTxt} onChange={e=>setCommentTxt(e.target.value)}
                onKeyDown={e=>{if(e.key==='Enter'&&commentTxt.trim())doComment(post.id);}}/>
              <button onClick={()=>doComment(post.id)} style={{background:th.p,border:'none',borderRadius:9,padding:'9px 13px',cursor:'pointer',color:'white',display:'flex'}}><Send c="white"/></button>
            </div>:<p style={{fontSize:12,color:th.txs,textAlign:'center',marginTop:8}}>
              <button onClick={()=>{setSelectedPost(null);go('login');}} style={{background:'none',border:'none',color:th.p,cursor:'pointer',fontWeight:700,fontSize:12}}>Inicia sesión</button> para comentar
            </p>}
          </div>
          {related.length>0&&<div>
            <p style={{fontSize:11,fontWeight:700,color:th.txs,textTransform:'uppercase',letterSpacing:.5,marginBottom:12}}>Publicaciones similares</p>
            <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(140px,1fr))',gap:10}}>
              {related.map(r=><div key={r.id} onClick={()=>setSelectedPost(r.id)} style={{borderRadius:10,overflow:'hidden',cursor:'pointer',border:`1px solid ${th.bd}`,transition:'transform .15s'}}
                onMouseEnter={e=>e.currentTarget.style.transform='scale(1.02)'}
                onMouseLeave={e=>e.currentTarget.style.transform='scale(1)'}>
                <img src={r.img} alt={r.title} style={{width:'100%',height:80,objectFit:'cover',display:'block'}}/>
                <p style={{fontSize:11,fontWeight:500,color:th.tx,padding:'6px 8px',margin:0,overflow:'hidden',display:'-webkit-box',WebkitLineClamp:2,WebkitBoxOrient:'vertical'}}>{r.title}</p>
              </div>)}
            </div>
          </div>}
        </div>
      </div>
    </div>
  );
});

/* ═══ SETTINGS PANEL (module level) ════════════════════════════ */
const SettingsPanel=memo(({C})=>{
  const{th,thKey,setThKey,dark,setDark,setShowSettings,user,setUser,toast_,rdF_}=C;
  const s={bg:th.sf,bd:th.bd,tx:th.tx,txs:th.txs,p:th.p,l:th.l,d:th.d};
  const inp={width:'100%',padding:'9px 12px',border:`1.5px solid ${s.bd}`,borderRadius:9,fontSize:13,background:th.bg,color:s.tx,boxSizing:'border-box',outline:'none'};
  const lbl={fontSize:11,fontWeight:600,color:s.txs,display:'block',marginBottom:5,textTransform:'uppercase',letterSpacing:.5};
  return(
    <div onClick={e=>{if(e.target===e.currentTarget)setShowSettings(false);}} style={{position:'fixed',inset:0,zIndex:150,display:'flex',justifyContent:'flex-end'}}>
      <div style={{width:300,height:'100%',background:s.bg,borderLeft:`1px solid ${s.bd}`,padding:'1.25rem',overflowY:'auto',display:'flex',flexDirection:'column',gap:'1.25rem',animation:'slideLeft .25s ease'}}>
        <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
          <h2 style={{fontSize:16,fontWeight:700,color:s.tx,margin:0}}>Configuración</h2>
          <button onClick={()=>setShowSettings(false)} style={{background:'none',border:'none',cursor:'pointer',color:s.txs,fontSize:22,lineHeight:1}}>×</button>
        </div>
        {user&&<>
          <div>
            <p style={lbl}>Perfil</p>
            <label style={{display:'flex',alignItems:'center',gap:10,cursor:'pointer',marginBottom:11}}>
              <Av name={user.name} avatar={user.avatar} size={44} th={th}/>
              <span style={{fontSize:12,color:s.p,fontWeight:600}}>Cambiar foto</span>
              <input type="file" accept="image/*" style={{display:'none'}} onChange={e=>{const f=e.target.files[0];if(f)rdF_(f,av=>setUser(u=>({...u,avatar:av})));}}/>
            </label>
            <div style={{display:'flex',flexDirection:'column',gap:9}}>
              <div><label style={lbl}>Nombre</label><input style={inp} value={user.name} onChange={e=>setUser(u=>({...u,name:e.target.value}))}/></div>
              <div><label style={lbl}>Biografía</label><textarea style={{...inp,minHeight:55,resize:'none'}} value={user.bio||''} onChange={e=>setUser(u=>({...u,bio:e.target.value}))}/></div>
            </div>
          </div>
          <div style={{borderTop:`1px solid ${s.bd}`,paddingTop:'1rem'}}>
            <p style={lbl}>Privacidad</p>
            <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:10}}>
              <div style={{flex:1}}>
                <p style={{fontSize:13,color:s.tx,margin:'0 0 2px'}}>Perfil público</p>
                <p style={{fontSize:11,color:s.txs,margin:0}}>Cualquiera puede ver tus proyectos</p>
              </div>
              <Tog on={user.isPublic} toggle={()=>setUser(u=>({...u,isPublic:!u.isPublic}))} p={s.p}/>
            </div>
            <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
              <div style={{flex:1}}>
                <p style={{fontSize:13,color:s.tx,margin:'0 0 2px'}}>Notificaciones</p>
                <p style={{fontSize:11,color:s.txs,margin:0}}>Avisos de likes y comentarios</p>
              </div>
              <Tog on={user.notifs!==false} toggle={()=>setUser(u=>({...u,notifs:!u.notifs}))} p={s.p}/>
            </div>
          </div>
        </>}
        <div style={{borderTop:`1px solid ${s.bd}`,paddingTop:'1rem'}}>
          <p style={lbl}>Apariencia</p>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'1rem'}}>
            <span style={{fontSize:13,color:s.tx,display:'flex',alignItems:'center',gap:6}}>{dark?<Moon/>:<Sun/>}{dark?'Modo oscuro':'Modo claro'}</span>
            <Tog on={dark} toggle={()=>setDark(d=>!d)} p={s.p}/>
          </div>
          <p style={{...lbl,marginBottom:9}}>Tema de color</p>
          <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:7}}>
            {Object.entries(TH).map(([k,t])=>(
              <button key={k} onClick={()=>setThKey(k)} style={{padding:'8px 10px',borderRadius:9,cursor:'pointer',border:`2px solid ${thKey===k?t.p:s.bd}`,background:thKey===k?(t.l+'88'):th.bg,display:'flex',alignItems:'center',gap:6,transition:'all .15s'}}>
                <div style={{width:10,height:10,borderRadius:'50%',background:t.p,flexShrink:0}}/>
                <span style={{fontSize:12,color:s.tx,fontWeight:thKey===k?700:400}}>{t.e} {t.n}</span>
              </button>
            ))}
          </div>
        </div>
        <div style={{borderTop:`1px solid ${s.bd}`,paddingTop:'1rem'}}>
          <p style={lbl}><Shield s={11} c={s.txs}/> Seguridad</p>
          <div style={{background:th.l,borderRadius:10,padding:'10px 12px',fontSize:12,color:s.d,lineHeight:1.6}}>
            Todo el contenido publicado es revisado por moderación automática con IA antes de aparecer en el feed.
          </div>
        </div>
        {user&&<button onClick={()=>{setUser(null);setShowSettings(false);}} style={{padding:10,border:'1.5px solid #ef4444',borderRadius:10,background:'transparent',color:'#ef4444',cursor:'pointer',fontSize:13,fontWeight:500,marginTop:'auto'}}>Cerrar sesión</button>}
      </div>
    </div>
  );
});

/* ═══ NAVBAR (module level) ════════════════════════════════════ */
const NavBar=memo(({C})=>{
  const{th,page,go,user,setShowSettings,msgs}=C;
  const unread=Object.values(msgs).flat().filter(m=>m.from!==user?.id&&!m.read).length;
  return(
    <nav style={{position:'sticky',top:0,zIndex:100,background:th.sf+'f0',backdropFilter:'blur(12px)',borderBottom:`1px solid ${th.bd}`,height:52,display:'flex',alignItems:'center',justifyContent:'space-between',padding:'0 1.1rem',gap:8}}>
      <button onClick={()=>go(user?'feed':'landing')} style={{display:'flex',alignItems:'center',gap:8,background:'none',border:'none',cursor:'pointer',padding:0}}>
        <div style={{width:30,height:30,background:th.p,borderRadius:9,display:'flex',alignItems:'center',justifyContent:'center',boxShadow:`0 2px 8px ${th.p}50`}}><Leaf s={16}/></div>
        <span style={{fontSize:17,fontWeight:700,color:th.tx,letterSpacing:'-.4px'}}>Ayni</span>
      </button>
      <div style={{display:'flex',gap:2,alignItems:'center'}}>
        {user?<>
          {[['feed','Feed'],['create','Publicar'],['marketplace','Materiales'],['ai','IA']].map(([p,l])=>(
            <button key={p} onClick={()=>go(p)} style={{background:page===p?th.l:'transparent',color:page===p?th.d:th.txs,border:'none',borderRadius:8,padding:'5px 9px',cursor:'pointer',fontSize:12,fontWeight:page===p?700:400,transition:'all .15s'}}>{l}</button>
          ))}
          <button onClick={()=>go('messages')} style={{position:'relative',background:page==='messages'?th.l:'transparent',border:'none',borderRadius:8,padding:'5px 8px',cursor:'pointer',display:'flex',transition:'all .15s'}}>
            <MsgIc s={16} c={page==='messages'?th.d:th.txs}/>
            {unread>0&&<span style={{position:'absolute',top:2,right:2,width:8,height:8,borderRadius:'50%',background:'#ef4444',border:`1.5px solid ${th.sf}`}}/>}
          </button>
          <button onClick={()=>go('profile')} style={{margin:'0 2px',background:'none',border:'none',cursor:'pointer',padding:0}}>
            <Av name={user.name} avatar={user.avatar} size={26} th={th}/>
          </button>
          <button onClick={()=>setShowSettings(true)} style={{background:'none',border:'none',cursor:'pointer',color:th.txs,padding:4,display:'flex'}}><Gear s={15} c={th.txs}/></button>
        </>:<>
          <button onClick={()=>setShowSettings(true)} style={{background:'none',border:'none',cursor:'pointer',color:th.txs,padding:5,display:'flex',marginRight:3}}><Gear s={15} c={th.txs}/></button>
          <button onClick={()=>go('login')} style={{background:'transparent',color:th.p,border:`1.5px solid ${th.p}`,borderRadius:9,padding:'6px 12px',cursor:'pointer',fontSize:12,fontWeight:500}}>Entrar</button>
          <button onClick={()=>go('register')} style={{background:th.p,color:'white',border:'none',borderRadius:9,padding:'6px 12px',cursor:'pointer',fontSize:12,fontWeight:500}}>Registrarse</button>
        </>}
      </div>
    </nav>
  );
});

/* ═══ AUTH PAGE (module level) ══════════════════════════════════ */
const AuthPage=memo(({C,isLogin})=>{
  const{th,aName,setAName,aEmail,setAEmail,aPass,setAPass,aErr,doLogin,doRegister,go}=C;
  const inp={width:'100%',padding:'10px 13px',border:`1.5px solid ${th.bd}`,borderRadius:10,fontSize:14,background:th.sf,color:th.tx,boxSizing:'border-box',outline:'none',transition:'border .2s'};
  const strength=pwStrength(aPass);
  const sColors=['#e5e7eb','#ef4444','#f97316','#eab308','#22c55e'];
  const sLabels=['','Muy débil','Débil','Media','Fuerte'];
  return(
    <div style={{minHeight:'80vh',display:'flex',alignItems:'center',justifyContent:'center',padding:'2rem 1rem'}}>
      <div style={{background:th.sf,border:`1px solid ${th.bd}`,borderRadius:18,width:'100%',maxWidth:360,padding:'1.75rem',animation:'slideUp .3s ease'}}>
        <div style={{textAlign:'center',marginBottom:'1.5rem'}}>
          <div style={{width:48,height:48,background:th.p,borderRadius:13,display:'flex',alignItems:'center',justifyContent:'center',margin:'0 auto .9rem',boxShadow:`0 6px 18px ${th.p}40`}}><Leaf s={22}/></div>
          <h2 style={{fontSize:20,fontWeight:800,color:th.tx,margin:'0 0 4px',letterSpacing:'-.3px'}}>{isLogin?'Bienvenido de vuelta':'Únete a Ayni'}</h2>
          <p style={{color:th.txs,fontSize:13}}>{isLogin?'Inicia sesión para continuar':'Crea tu cuenta gratis'}</p>
        </div>
        <div style={{display:'flex',flexDirection:'column',gap:12}}>
          {!isLogin&&<div><label style={{fontSize:11,fontWeight:600,color:th.txs,display:'block',marginBottom:5,textTransform:'uppercase',letterSpacing:.5}}>Nombre completo</label>
            <input style={inp} placeholder="Tu nombre" value={aName} onChange={e=>setAName(e.target.value)}/></div>}
          <div><label style={{fontSize:11,fontWeight:600,color:th.txs,display:'block',marginBottom:5,textTransform:'uppercase',letterSpacing:.5}}>Correo electrónico</label>
            <input style={inp} type="email" placeholder="tu@correo.com" value={aEmail} onChange={e=>setAEmail(e.target.value)} onKeyDown={e=>e.key==='Enter'&&(isLogin?doLogin():doRegister())}/></div>
          <div>
            <label style={{fontSize:11,fontWeight:600,color:th.txs,display:'block',marginBottom:5,textTransform:'uppercase',letterSpacing:.5}}>Contraseña</label>
            <input style={inp} type="password" placeholder="Mínimo 6 caracteres" value={aPass} onChange={e=>setAPass(e.target.value)} onKeyDown={e=>e.key==='Enter'&&(isLogin?doLogin():doRegister())}/>
            {!isLogin&&aPass.length>0&&<div style={{marginTop:7}}>
              <div style={{display:'flex',gap:3,marginBottom:4}}>
                {[1,2,3,4].map(i=><div key={i} style={{flex:1,height:3,borderRadius:2,background:i<=strength?sColors[strength]:'#e5e7eb',transition:'background .3s'}}/>)}
              </div>
              <span style={{fontSize:11,color:sColors[strength]}}>{aPass.length>0?sLabels[strength]:''}</span>
            </div>}
          </div>
          {aErr&&<p style={{fontSize:12,color:'#dc2626',background:'#fee2e2',padding:'8px 11px',borderRadius:8,margin:0}}>{aErr}</p>}
          <button onClick={isLogin?doLogin:doRegister} style={{background:th.p,color:'white',border:'none',borderRadius:10,padding:12,fontSize:14,fontWeight:600,cursor:'pointer',marginTop:2,boxShadow:`0 4px 14px ${th.p}30`,transition:'opacity .15s'}}>
            {isLogin?'Iniciar sesión':'Crear cuenta'}
          </button>
        </div>
        <p style={{textAlign:'center',fontSize:12,color:th.txs,marginTop:14}}>
          {isLogin?'¿No tienes cuenta? ':'¿Ya tienes cuenta? '}
          <button onClick={()=>go(isLogin?'register':'login')} style={{background:'none',border:'none',color:th.p,cursor:'pointer',fontWeight:700,fontSize:12,padding:0}}>
            {isLogin?'Regístrate':'Inicia sesión'}
          </button>
        </p>
        {isLogin&&<p style={{textAlign:'center',fontSize:11,color:th.txt,marginTop:8,padding:'6px',background:th.bg,borderRadius:7}}>Demo: email válido + contraseña de 6+ caracteres</p>}
      </div>
    </div>
  );
});

/* ═══ FEED PAGE (module level) ══════════════════════════════════ */
const FeedPage=memo(({C})=>{
  const{th,posts,go,user,filter,setFilter}=C;
  const filtered=filter==='all'?posts:posts.filter(p=>p.type===filter);
  const btn={background:th.p,color:'white',border:'none',borderRadius:9,padding:'7px 13px',cursor:'pointer',fontSize:12,fontWeight:600,display:'inline-flex',alignItems:'center',gap:6};
  return(
    <div style={{maxWidth:1100,margin:'0 auto',padding:'1.5rem 1rem'}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'1.1rem',flexWrap:'wrap',gap:8}}>
        <div><h1 style={{fontSize:20,fontWeight:800,color:th.tx,margin:0,letterSpacing:'-.4px'}}>Explorar</h1>
          <p style={{fontSize:12,color:th.txs,marginTop:3}}>{filtered.length} publicaciones en la comunidad Ayni</p></div>
        <div style={{display:'flex',gap:7,flexWrap:'wrap',alignItems:'center'}}>
          {[['all','Todos'],['project','Proyectos'],['material','Materiales']].map(([v,l])=>(
