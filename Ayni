/* ═══ MAIN APP ══════════════════════════════════════════════════ */
export default function App() {
  const [thKey,    setThKey]   = useState('forest');
  const [dark,     setDark]    = useState(false);
  const [page,     setPage]    = useState('landing');
  const [user,     setUser]    = useState(null);
  const [posts,    setPosts]   = useState(INIT_POSTS);
  const [liked,    setLiked]   = useState(new Set());
  const [saved,    setSaved]   = useState(new Set());
  const [filter,   setFilter]  = useState('all');
  const [showSettings, setShowSettings] = useState(false);
  const [toast,    setToast]   = useState(null);
  const [selectedPost, setSelectedPost] = useState(null);
  const [msgs,     setMsgs]   = useState(INIT_MSGS);
  const [activeMsgUser, setActiveMsgUser] = useState('ayni_off');
  const [commentTxt, setCommentTxt] = useState('');
  const [aiIn,     setAiIn]   = useState('');
  const [aiIdeas,  setAiIdeas] = useState([]);
  const [aiLoading,setAiLoading] = useState(false);
  const [aiErr,    setAiErr]  = useState('');
  // Auth
  const [aName,setAName]=useState('');const [aEmail,setAEmail]=useState('');const [aPass,setAPass]=useState('');const [aErr,setAErr]=useState('');
  // Create post
  const [cp, setCp] = useState({type:'project',title:'',desc:'',img:null,mats:[],matIn:'',steps:[''],qty:'',loc:''});
  const [aiMod, setAiMod] = useState({checking:false,err:''});

  const th = getT(thKey, dark);
  const toast_ = (msg,type='ok') => { setToast({msg,type}); setTimeout(()=>setToast(null),2800); };
  const go = p => { setPage(p); setAErr(''); setShowSettings(false); };

  const doLogin = () => {
    if(!aEmail||aPass.length<6){setAErr('Email válido y contraseña de 6+ caracteres');return;}
    setUser({id:`u${Date.now()}`,name:aEmail.split('@')[0],email:aEmail,bio:'Apasionado por la economía circular.',avatar:null,isPublic:true,co2:0});
    setAEmail('');setAPass('');setAErr('');toast_('Sesión iniciada');go('feed');
  };
  const doRegister = () => {
    if(!aName||!aEmail||aPass.length<6){setAErr('Completa todos los campos (mínimo 6 caracteres)');return;}
    setUser({id:`u${Date.now()}`,name:aName,email:aEmail,bio:'Nuevo en Ayni.',avatar:null,isPublic:true,co2:0});
    setAName('');setAEmail('');setAPass('');setAErr('');toast_('Cuenta creada');go('feed');
  };
  const doLike = id => {
    if(!user){go('login');return;}
    setLiked(prev=>{const n=new Set(prev);n.has(id)?(n.delete(id),setPosts(ps=>ps.map(p=>p.id===id?{...p,likes:p.likes-1}:p))):(n.add(id),setPosts(ps=>ps.map(p=>p.id===id?{...p,likes:p.likes+1}:p)));return n;});
  };
  const doSave = id => {
    if(!user){go('login');return;}
    setSaved(prev=>{const n=new Set(prev);n.has(id)?n.delete(id):n.add(id);return n;});
    toast_(saved.has(id)?'Eliminado de guardados':'Guardado para después');
  };
  const doComment = postId => {
    if(!user||!commentTxt.trim())return;
    setPosts(ps=>ps.map(p=>p.id===postId?{...p,comments:[...p.comments,{id:`c${Date.now()}`,author:user.name,text:commentTxt,ts:Date.now()}]}:p));
    setCommentTxt('');
  };
  const sendMsg = (toId, text) => {
    const msg={id:`msg${Date.now()}`,from:user.id,text,ts:Date.now(),read:true};
    setMsgs(m=>({...m,[toId]:[...(m[toId]||[]),msg]}));
  };

  const submitPost = async () => {
    if(!cp.title.trim()){toast_('El título es obligatorio','err');return;}
    setAiMod({checking:true,err:''});
    let ok=true;
    try{
      const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:120,messages:[{role:'user',content:`Eres moderador de Ayni, plataforma de reciclaje. ¿Es este contenido apropiado para la plataforma? Responde SOLO con JSON: {"ok":true,"reason":""}\nTítulo: ${cp.title}\nDescripción: ${cp.desc}`}]})});
      const d=await res.json();const r=JSON.parse(d.content[0].text.replace(/```json|```/g,'').trim());
      if(!r.ok){setAiMod({checking:false,err:`Contenido rechazado: ${r.reason}`});return;}
    }catch{/* allow if API fails */}
    setAiMod({checking:false,err:''});
    setPosts(ps=>[{id:`p${Date.now()}`,type:cp.type,authorId:user.id,author:user.name,title:cp.title,desc:cp.desc,img:cp.img||mkImg(ps.length),mats:[...cp.mats],steps:cp.steps.filter(s=>s.trim()),likes:0,comments:[],created:Date.now(),...(cp.type==='material'?{qty:cp.qty,location:cp.loc}:{})},...ps]);
    setUser(u=>({...u,co2:(u.co2||0)+Math.ceil(Math.random()*5+1)}));
    setCp({type:'project',title:'',desc:'',img:null,mats:[],matIn:'',steps:[''],qty:'',loc:''});
    toast_('Publicación creada');go('feed');
  };

  const doAI = async () => {
    if(!aiIn.trim())return;
    setAiLoading(true);setAiErr('');setAiIdeas([]);
    try{
      const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1500,messages:[{role:'user',content:`Eres experto en economía circular para Pasto, Nariño. El usuario tiene: ${aiIn}. Genera exactamente 3 proyectos creativos. Responde SOLO con JSON sin markdown:\n{"ideas":[{"titulo":"","descripcion":"","materiales":[],"pasos":[],"impacto":"","dificultad":"Fácil"}]}`}]})});
      const d=await res.json();setAiIdeas(JSON.parse(d.content[0].text.replace(/```json|```/g,'').trim()).ideas||[]);
    }catch{setAiErr('No se pudo conectar con la IA.');}
    setAiLoading(false);
  };

  const C={th,thKey,setThKey,dark,setDark,page,go,user,setUser,posts,liked,saved,filter,setFilter,doLike,doSave,doComment,commentTxt,setCommentTxt,selectedPost,setSelectedPost,showSettings,setShowSettings,toast_,msgs,sendMsg,activeMsgUser,setActiveMsgUser,aName,setAName,aEmail,setAEmail,aPass,setAPass,aErr,setAErr,doLogin,doRegister,cp,setCp,submitPost,aiMod,aiIn,setAiIn,aiIdeas,doAI,aiLoading,aiErr,rdF_:rdF};

  return(
    <div style={{minHeight:'100vh',background:th.bg,color:th.tx,fontFamily:'-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif',transition:'background .3s,color .3s'}}>
      <style>{`
        @keyframes fadeIn{from{opacity:0}to{opacity:1}}
        @keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
        @keyframes slideLeft{from{transform:translateX(100%)}to{transform:translateX(0)}}
        @keyframes spin{to{transform:rotate(360deg)}}
        *{box-sizing:border-box;margin:0}
        ::-webkit-scrollbar{width:5px;height:5px}
        ::-webkit-scrollbar-thumb{background:${th.l};border-radius:10px}
        ::-webkit-scrollbar-track{background:transparent}
        input,textarea,select{font-family:inherit}
      `}</style>
      <NavBar C={C}/>
      {toast&&<div style={{position:'fixed',top:60,right:16,zIndex:300,background:toast.type==='err'?'#fee2e2':th.l,color:toast.type==='err'?'#991b1b':th.d,padding:'10px 16px',borderRadius:11,fontSize:13,fontWeight:600,boxShadow:'0 6px 22px rgba(0,0,0,.12)',animation:'slideUp .25s ease',maxWidth:280}}>
        {toast.msg}
      </div>}
      {showSettings&&<SettingsPanel C={C}/>}
      {selectedPost&&<PostDetail C={C}/>}
      <div key={page} style={{animation:'fadeUp .28s ease'}}>
        {page==='landing'&&<LandingPage C={C}/>}
        {page==='login'&&<AuthPage C={C} isLogin={true}/>}
        {page==='register'&&<AuthPage C={C} isLogin={false}/>}
        {page==='feed'&&<FeedPage C={C}/>}
        {page==='create'&&(user?<CreatePage C={C}/>:<AuthPage C={C} isLogin/>)}
        {page==='marketplace'&&<MarketplacePage C={C}/>}
        {page==='ai'&&<AIPage C={C}/>}
        {page==='profile'&&(user?<ProfilePage C={C}/>:<AuthPage C={C} isLogin/>)}
        {page==='messages'&&(user?<MessagesPage C={C}/>:<AuthPage C={C} isLogin/>)}
      </div>
      <style>{`@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}`}</style>
    </div>
  );
}
