      </div>
      <div style={{padding:'10px 12px'}}>
        <div style={{display:'flex',alignItems:'center',gap:7,marginBottom:6}}>
          <Av name={post.author} size={20} verified={post.verified} th={th}/>
          <span style={{fontSize:11,color:th.txs,flex:1}}>{post.author}</span>
          <span style={{fontSize:10,color:th.txt}}>{ago(post.created)}</span>
        </div>
        <p style={{fontWeight:600,fontSize:13.5,lineHeight:1.42,marginBottom:5,color:th.tx}}>{post.title}</p>
        <p style={{fontSize:12,color:th.txs,lineHeight:1.55,marginBottom:8,overflow:'hidden',display:'-webkit-box',WebkitLineClamp:2,WebkitBoxOrient:'vertical'}}>{post.desc}</p>
        {post.mats?.length>0&&<div style={{display:'flex',flexWrap:'wrap',gap:4,marginBottom:8}}>
          {post.mats.slice(0,3).map(m=><span key={m} style={{fontSize:10,background:th.l,color:th.d,padding:'2px 7px',borderRadius:100}}>{m}</span>)}
        </div>}
        <div onClick={e=>e.stopPropagation()} style={{display:'flex',alignItems:'center',borderTop:`1px solid ${th.bd}`,paddingTop:8,gap:2}}>
          <button onClick={()=>doLike(post.id)} style={{background:'none',border:'none',cursor:'pointer',display:'flex',alignItems:'center',gap:4,color:liked.has(post.id)?'#ef4444':th.txs,fontSize:12,padding:'3px 7px',borderRadius:7}}>
