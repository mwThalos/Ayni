    <div onClick={()=>setSelectedPost(post.id)} style={{background:th.sf,border:`1px solid ${th.bd}`,borderRadius:16,overflow:'hidden',breakInside:'avoid',marginBottom:14,cursor:'pointer',transition:'transform .22s,box-shadow .22s'}}
