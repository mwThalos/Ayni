      onMouseLeave={e=>{e.currentTarget.style.transform='translateY(0)';e.currentTarget.style.boxShadow='none';}}>
      <div style={{position:'relative'}}>
        <img src={post.img} alt={post.title} style={{width:'100%',display:'block'}}/>
        <span style={{position:'absolute',top:9,right:9,background:isM?'#0284c7':th.p,color:'white',fontSize:10,fontWeight:700,padding:'3px 8px',borderRadius:100,letterSpacing:.5}}>
          {isM?'Material':'Proyecto'}
